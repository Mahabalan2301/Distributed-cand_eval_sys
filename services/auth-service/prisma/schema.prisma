generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  status       String        @default("APPLIED")
  createdAt    DateTime      @default(now())
  applications Application[]
  responses    Response[]
  scores       Score[]

  @@index([status])
  @@index([createdAt])
}

model Question {
  id       String   @id @default(uuid())
  question String
  options  String[]
  answer   Int
}

model Application {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  status      String // Applied, Attempted, Evaluated
  score       Score?
  createdAt   DateTime  @default(now())

  @@index([candidateId])
  @@index([status])
}

model Response {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  questionId  String
  selected    Int

  @@index([candidateId])
  @@index([questionId])
}


model Score {
  id            String      @id @default(uuid())
  candidateId   String
  applicationId String      @unique
  candidate     Candidate   @relation(fields: [candidateId], references: [id])
  application   Application @relation(fields: [applicationId], references: [id])
  score         Int
  createdAt     DateTime    @default(now())

  @@index([candidateId])
  @@index([applicationId])
}